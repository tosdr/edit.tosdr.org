<div class="form-login">
  <div class="row row-form">
    <%= simple_form_for [service], html: {multipart: true} do |f| %>
      <div class="form-inputs col-xs-12">
        <%= f.input :name, placeholder: "Service name" %>
        <%= f.input :url, placeholder: "bbc.com,bbc.co.uk", label: "Domains, comma-separated (e.g. 'bbc.com,bbc.co.uk')"%>
        <%= f.input :wikipedia, placeholder: "Wikipedia link", hint: "This will be used to reference the Wikipedia link of the service. Used mostly for the API." %>
        <%- # Only allow marking services as completely reviewed if they are not new, because new services have no reviews yet: %>
        <% if service.id && current_user.curator? %>
          <%= f.input :is_comprehensively_reviewed, label: "This service's ToS;DR review is <a href=\"https://github.com/tosdr/tosdr.org/wiki/checklist\" target=\"_blank\" title=\"Checklist for service reviews\">comprehensive</a> and ready for publication.".html_safe %>
        <% end %>
         
        <label>Logo (.png)</label>
        <%= f.file_field :logo, label: "Logo (.png)", accept: "image/png" %>

        <% if service.id && (current_user.curator? || current_user.admin?) %>
          <div style="margin-top: 10px;">
            <label>Fetch Logo from Domain</label>
            <div>
              <button type="button" id="fetch-logo-btn" class="btn btn-default"
                      data-fetch-url="<%= fetch_service_logo_path(service) %>"
                      data-approve-url="<%= approve_service_logo_path(service) %>">
                Fetch Logo
              </button>
            </div>
            <div id="logo-fetch-preview" style="display:none; margin-top:10px;">
              <img id="fetched-logo-img" src="" alt="Logo preview"
                   style="max-width:128px; max-height:128px; border:1px solid #ccc; display:block; margin-bottom:8px;" />
              <button type="button" id="approve-logo-btn" class="btn btn-success">Approve</button>
              <button type="button" id="reject-logo-btn" class="btn btn-danger">Reject</button>
            </div>
            <p id="logo-fetch-status" style="margin-top:6px;"></p>
          </div>
          <script>
            (function() {
              var fetchBtn   = document.getElementById('fetch-logo-btn');
              var approveBtn = document.getElementById('approve-logo-btn');
              var rejectBtn  = document.getElementById('reject-logo-btn');
              var preview    = document.getElementById('logo-fetch-preview');
              var logoImg    = document.getElementById('fetched-logo-img');
              var statusEl   = document.getElementById('logo-fetch-status');
              var csrfToken  = function() {
                var el = document.querySelector('meta[name="csrf-token"]');
                return el ? el.content : '';
              };

              fetchBtn.addEventListener('click', function() {
                fetchBtn.disabled = true;
                fetchBtn.textContent = 'Fetching...';
                statusEl.textContent = '';
                preview.style.display = 'none';

                fetch(fetchBtn.dataset.fetchUrl, {
                  headers: { 'X-CSRF-Token': csrfToken(), 'Accept': 'application/json' }
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                  fetchBtn.disabled = false;
                  fetchBtn.textContent = 'Fetch Logo';
                  if (data.error) {
                    statusEl.textContent = data.error;
                  } else {
                    logoImg.src = 'data:image/png;base64,' + data.image;
                    preview.style.display = 'block';
                    approveBtn.disabled = false;
                    approveBtn.textContent = 'Approve';
                  }
                })
                .catch(function() {
                  fetchBtn.disabled = false;
                  fetchBtn.textContent = 'Fetch Logo';
                  statusEl.textContent = 'Failed to fetch logo.';
                });
              });

              approveBtn.addEventListener('click', function() {
                approveBtn.disabled = true;
                approveBtn.textContent = 'Approving...';
                statusEl.textContent = '';

                fetch(fetchBtn.dataset.approveUrl, {
                  method: 'POST',
                  headers: { 'X-CSRF-Token': csrfToken(), 'Accept': 'application/json' }
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                  if (data.success) {
                    statusEl.textContent = 'Logo approved and saved!';
                    preview.style.display = 'none';
                  } else {
                    approveBtn.disabled = false;
                    approveBtn.textContent = 'Approve';
                    statusEl.textContent = data.error || 'Failed to approve logo.';
                  }
                })
                .catch(function() {
                  approveBtn.disabled = false;
                  approveBtn.textContent = 'Approve';
                  statusEl.textContent = 'Failed to approve logo.';
                });
              });

              rejectBtn.addEventListener('click', function() {
                preview.style.display = 'none';
                logoImg.src = '';
                statusEl.textContent = '';
              });
            })();
          </script>
        <% end %>
      </div>
      <%= invisible_captcha :description %>
      <div class="form-actions col-xs-4 col-sm-2 col-md-2">
          <%= link_to "Back", :back, class: "btn btn-default" %>
      </div>
      <div class="form-actions col-xs-8 col-sm-4 col-sm-offset-6 col-md-3 col-md-offset-7">
        <%= f.submit class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
</div>
